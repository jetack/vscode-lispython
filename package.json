{
  "name": "vscode-lispython",
  "displayName": "LisPython",
  "description": "Language support for LisPython (.lpy) — a Lisp-like syntax for Python",
  "version": "0.2.2",
  "publisher": "jetack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jetack/vscode-lispython"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:lispython",
    "onCommand:lispython.selectPythonPath",
    "onCommand:lispython.restartServer",
    "onCommand:lispython.runFile",
    "onCommand:lispython.startRepl",
    "onCommand:lispython.sendToRepl",
    "onCommand:lispython.sendLastSexp",
    "onCommand:lispython.sendTopLevelForm"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lispython.selectPythonPath",
        "title": "LisPython: Select Python Interpreter"
      },
      {
        "command": "lispython.restartServer",
        "title": "LisPython: Restart Language Server"
      },
      {
        "command": "lispython.runFile",
        "title": "LisPython: Run File",
        "icon": "$(play)"
      },
      {
        "command": "lispython.startRepl",
        "title": "LisPython: Start REPL",
        "icon": "$(terminal)"
      },
      {
        "command": "lispython.sendToRepl",
        "title": "LisPython: Send Selection to REPL"
      },
      {
        "command": "lispython.sendLastSexp",
        "title": "LisPython: Send Last S-Expression to REPL"
      },
      {
        "command": "lispython.sendTopLevelForm",
        "title": "LisPython: Send Top-Level Form to REPL"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceLangId == lispython",
          "command": "lispython.runFile",
          "group": "navigation@1"
        },
        {
          "when": "resourceLangId == lispython",
          "command": "lispython.startRepl",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == lispython && editorHasSelection",
          "command": "lispython.sendToRepl",
          "group": "lispython@1"
        },
        {
          "when": "resourceLangId == lispython",
          "command": "lispython.sendLastSexp",
          "group": "lispython@2"
        },
        {
          "when": "resourceLangId == lispython",
          "command": "lispython.sendTopLevelForm",
          "group": "lispython@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lispython.sendLastSexp",
        "key": "ctrl+enter",
        "when": "editorTextFocus && resourceLangId == lispython && !editorHasSelection"
      },
      {
        "command": "lispython.sendToRepl",
        "key": "ctrl+enter",
        "when": "editorTextFocus && resourceLangId == lispython && editorHasSelection"
      },
      {
        "command": "lispython.sendTopLevelForm",
        "key": "ctrl+alt+enter",
        "when": "editorTextFocus && resourceLangId == lispython"
      }
    ],
    "languages": [
      {
        "id": "lispython",
        "aliases": [
          "LisPython",
          "lispython",
          "lpy"
        ],
        "extensions": [
          ".lpy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lispython",
        "scopeName": "source.lispython",
        "path": "./syntaxes/lispython.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "LisPython",
      "properties": {
        "lispython.lsp.pythonPath": {
          "type": "string",
          "default": "python3",
          "markdownDescription": "Python interpreter with `lispython` installed. The LSP server is launched as `<pythonPath> -m lispy.lsp`. Pick a Python that has the [lispython](https://pypi.org/project/lispython/) package installed (commonly a project's `.venv/bin/python`)."
        },
        "lispython.lpyPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `lpy` executable used by `Run File` and the REPL. If empty, looks next to the selected Python interpreter, then falls back to `lpy` on PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
